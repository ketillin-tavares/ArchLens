									"    pm.expect(json).to.have.property('diagrama_id');",
									"    pm.expect(json).to.have.property('status');",
									"    pm.expect(json).to.have.property('criado_em');",
									"    pm.expect(json).to.have.property('atualizado_em');",
									"",
									"    var validStatuses = ['recebido', 'processando', 'concluido', 'erro'];",
									"    pm.expect(validStatuses).to.include(json.status);",
									"",
