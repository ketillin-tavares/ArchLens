		{
			"name": "Fluxo Completo (Happy Path)",
			"description": "Fluxo end-to-end completo: upload → polling → processamento → relatório.\n\nExecute as requests na ordem para testar o pipeline inteiro.",
			"item": [
				{
					"name": "1. Upload Diagrama",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Upload aceito com status 202', function () {",
									"    pm.response.to.have.status(202);",
									"});",
									"",
									"pm.test('Resposta contém analise_id', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('analise_id');",
									"    pm.expect(json.status).to.eql('recebido');",
									"    pm.expect(json).to.have.property('criado_em');",
									"",
									"    pm.collectionVariables.set('analise_id', json.analise_id);",
									"    console.log('analise_id salvo:', json.analise_id);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": "",
									"description": "Selecione um arquivo PNG, JPEG ou PDF (max 10MB)"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/v1/analises",
							"host": ["{{base_url}}"],
							"path": ["v1", "analises"]
						},
						"description": "Envia um diagrama de arquitetura para análise.\n\n**Tipos aceitos:** image/png, image/jpeg, application/pdf\n**Tamanho máximo:** 10MB\n\nO `analise_id` retornado é salvo automaticamente na variável `{{analise_id}}` para uso nas próximas requests."
					},
					"response": [
						{
							"name": "202 - Upload aceito",
							"originalRequest": {
								"method": "POST",
								"header": [],
								"body": {
									"mode": "formdata",
									"formdata": [{"key": "file", "type": "file", "src": ""}]
								},
								"url": {
									"raw": "{{base_url}}/v1/analises",
									"host": ["{{base_url}}"],
									"path": ["v1", "analises"]
								}
							},
							"status": "Accepted",
							"code": 202,
