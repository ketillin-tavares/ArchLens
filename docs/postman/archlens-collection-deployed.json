							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Consulta de status retorna 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Resposta contém campos esperados', function () {",
									"    var json = pm.response.json();",
