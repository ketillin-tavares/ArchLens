# Configurações do Banco de Dados PostgreSQL
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=report_user
DATABASE_PASSWORD=report_pass
DATABASE_NAME=report_db

# Configurações do RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=archlens
RABBITMQ_PASSWORD=archlens_dev
RABBITMQ_EXCHANGE_NAME=analise.events
RABBITMQ_QUEUE_NAME=report-service.reports

# Configurações da Aplicação
SERVICE_NAME=report-service
DEBUG=false
LOG_LEVEL=INFO

# Configurações do S3/LocalStack
S3_ENDPOINT_URL=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=archlens-diagramas
AWS_REGION=us-east-1

# Configurações do LiteLLM Proxy (text-only, para geração de Markdown)
LLM_BASE_URL=http://litellm:4000
LLM_API_KEY=sk-litellm-dev
LLM_MODEL_NAME=archlens-analyzer

# Configurações do NewRelic
NEW_RELIC_USER_KEY=abc
NEW_RELIC_LICENSE_KEY=abc
NEW_RELIC_ACCOUNT_ID=123
NRIA_DISPLAY_NAME=report-service
NRIA_LICENSE_KEY=abc
