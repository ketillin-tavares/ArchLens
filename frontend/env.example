# New Relic Browser (Pro+SPA) — opcional. Sem licenseKey o snippet em
# index.html no-op (nao baixa o loader). Obter os 5 valores em:
# one.newrelic.com > Add data > Browser > New > Copy/Paste > "Show snippet"
# Mapeamento: licenseKey, applicationID, accountID, agentID, trustKey
# do bloco NREUM.loader_config / NREUM.info.
VITE_NEWRELIC_LICENSE_KEY=
VITE_NEWRELIC_BROWSER_APP_ID=
VITE_NEWRELIC_ACCOUNT_ID=
VITE_NEWRELIC_BROWSER_AGENT_ID=
VITE_NEWRELIC_TRUST_KEY=
